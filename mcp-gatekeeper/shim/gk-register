#!/usr/bin/env python3
"""gk-register — лёгкий MCP-клиент для mcp-gatekeeper (порт 8888).
Делает handshake + вызывает register_port/register_timer.
Возвращает: ALLOW / REJECT / DEAD (при недоступности -> DEAD + контрактный ответ).
Используется shim-wrapper'ами systemctl/crontab и path-unit service.

Протокол ADR-0054: при недоступности Gatekeeper клиент возвращает контракт
"dead + heal + mandatory_retry" (см. ADR-0054).

Фаза 2 (ADR-0055): клиент подставляет РЕАЛЬНОГО агента, а не хардкодит 'shim'.
Агент берётся из аргумента; если аргумент 'auto'/пуст — резолвится из окружения
(AGENT_ID) или из дерева процессов вызывающего (PPID). Gatekeeper затем проверяет
глобальный диапазон + резерв по реальному агенту (per-agent пулов нет). as_root (root-bypass) передаётся только если
разрешён политикой для этого агента — и всегда аудируется.
"""
import json, os, sys, urllib.request

GK = "http://127.0.0.1:8888/mcp"
SID = None


def _ppid_of(pid: int) -> int:
    """PPID процесса pid из /proc/<pid>/stat (поле 4)."""
    try:
        with open(f"/proc/{pid}/stat") as f:
            s = f.read()
        # comm может содержать пробелы/скобки — берём последнее после последней ')'
        rp = s.rfind(")")
        if rp == -1:
            return 0
        fields = s[rp + 1:].split()
        if len(fields) >= 3:
            return int(fields[2])  # ppid
    except Exception:
        pass
    return 0


def resolve_agent() -> str:
    """Реальный агент: AGENT_ID env -> дерево процессов (environ) -> comm PPID -> 'unknown'."""
    a = os.environ.get("AGENT_ID")
    if a:
        return a
    # поднимаемся вверх по дереву процессов, ищем AGENT_ID в окружении предков
    try:
        pid = os.getpid()
        for _ in range(8):
            ppid = _ppid_of(pid)
            if ppid <= 1:
                break
            try:
                with open(f"/proc/{ppid}/environ", "rb") as f:
                    data = f.read().decode("utf-8", "replace")
                for kv in data.split("\0"):
                    if kv.startswith("AGENT_ID="):
                        val = kv.split("=", 1)[1]
                        if val:
                            return val
            except Exception:
                pass
            pid = ppid
    except Exception:
        pass
    # запасной вариант — имя процесса-родителя
    try:
        ppid = _ppid_of(os.getpid())
        if ppid > 1:
            with open(f"/proc/{ppid}/comm") as f:
                comm = f.read().strip()
            if comm:
                return comm
    except Exception:
        pass
    return "unknown"


def post(payload):
    global SID
    data = json.dumps(payload).encode()
    req = urllib.request.Request(GK, data=data, method="POST")
    req.add_header("Content-Type", "application/json")
    req.add_header("Accept", "application/json, text/event-stream")
    if SID:
        req.add_header("Mcp-Session-Id", SID)
    resp = urllib.request.urlopen(req, timeout=5)
    if "mcp-session-id" in resp.headers:
        SID = resp.headers["mcp-session-id"]
    body = resp.read().decode()
    for line in body.splitlines():
        if line.startswith("data:"):
            try:
                return json.loads(line[5:].strip())
            except Exception:
                pass
    return {}


def register_port(agent, project, port, what_for, as_root=False, bypass_reason=None, unit=None):
    try:
        post({"jsonrpc": "2.0", "id": 0, "method": "initialize",
              "params": {"protocolVersion": "2024-11-05", "capabilities": {},
                         "clientInfo": {"name": "gk-shim", "version": "1.0"}}})
        post({"jsonrpc": "2.0", "method": "notifications/initialized", "params": {}})
        r = post({"jsonrpc": "2.0", "id": 2, "method": "tools/call",
                  "params": {"name": "register_port",
                             "arguments": {"agent": agent, "project_id": project,
                                           "port": port, "what_for": what_for,
                                           "run_as": "", "as_root": bool(as_root),
                                           "bypass_reason": bypass_reason or "",
                                           "unit": unit or ""}}})
        txt = r.get("result", {}).get("content", [{}])[0].get("text", "")
        # gatekeeper отвечает полем 'status' (не 'decision')
        return json.loads(txt).get("status", "ERROR")
    except Exception:
        # Gatekeeper мёртв/недоступен — по ADR-0054 возвращаем контракт, не fail-open
        return "DEAD"


def register_timer(agent, project, schedule, action, what_for, as_root=False, bypass_reason=None, unit=None):
    try:
        post({"jsonrpc": "2.0", "id": 0, "method": "initialize",
              "params": {"protocolVersion": "2024-11-05", "capabilities": {},
                         "clientInfo": {"name": "gk-shim", "version": "1.0"}}})
        post({"jsonrpc": "2.0", "method": "notifications/initialized", "params": {}})
        r = post({"jsonrpc": "2.0", "id": 2, "method": "tools/call",
                  "params": {"name": "register_timer",
                             "arguments": {"agent": agent, "project_id": project,
                                           "action": action, "schedule": schedule,
                                           "what_for": what_for,
                                           "run_as": "", "as_root": bool(as_root),
                                           "bypass_reason": bypass_reason or "",
                                           "unit": unit or ""}}})
        txt = r.get("result", {}).get("content", [{}])[0].get("text", "")
        return json.loads(txt).get("status", "ERROR")
    except Exception:
        return "DEAD"


if __name__ == "__main__":
    if len(sys.argv) < 3 or sys.argv[1] not in ("port", "timer"):
        print("ERROR")
        sys.exit(0)

    as_root = "--as-root" in sys.argv
    bypass_reason = None
    unit = None
    if "--bypass-reason" in sys.argv:
        i = sys.argv.index("--bypass-reason")
        if i + 1 < len(sys.argv):
            bypass_reason = sys.argv[i + 1]
    if "--unit" in sys.argv:
        i = sys.argv.index("--unit")
        if i + 1 < len(sys.argv):
            unit = sys.argv[i + 1]

    if sys.argv[1] == "port":
        port = int(sys.argv[2])
        what_for = sys.argv[3] if len(sys.argv) > 3 else "shim"
        agent_arg = sys.argv[4] if len(sys.argv) > 4 else "auto"
        project = sys.argv[5] if len(sys.argv) > 5 else ""
        agent = resolve_agent() if (not agent_arg or agent_arg == "auto") else agent_arg
        if not project:
            project = agent
        res = register_port(agent, project, port, what_for, as_root=as_root, bypass_reason=bypass_reason, unit=unit)
    else:  # timer
        schedule = sys.argv[2]
        action = sys.argv[3] if len(sys.argv) > 3 else ""
        what_for = sys.argv[4] if len(sys.argv) > 4 else "shim"
        agent_arg = sys.argv[5] if len(sys.argv) > 5 else "auto"
        project = sys.argv[6] if len(sys.argv) > 6 else ""
        agent = resolve_agent() if (not agent_arg or agent_arg == "auto") else agent_arg
        if not project:
            project = agent
        res = register_timer(agent, project, schedule, action, what_for, as_root=as_root, bypass_reason=bypass_reason, unit=unit)

    if res == "DEAD":
        contract = {
            "status": "dead",
            "heal": "systemctl restart mcp-gatekeeper",
            "mandatory_retry": True,
            "message": "Gatekeeper мертв. Вылечи: systemctl restart mcp-gatekeeper, затем ОБЯЗАН повторить."
        }
        print("GATEKEEPER_DEAD " + json.dumps(contract, ensure_ascii=False))
        sys.exit(2)
    print(res)
    sys.exit(0 if res == "ALLOW" else 1)
