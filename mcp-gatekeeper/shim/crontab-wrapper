#!/usr/bin/env bash
# gatekeeper shim: PATH-wrapper для crontab (Слой 1).
# Перехват добавления заданий -> регистрация таймера в mcp-gatekeeper (8888).
# Таймеры не блокируем строго (PDP v1 не покрывает таймеры полностью), но аудируем.
set -u
ORIG=/usr/bin/crontab
HELPER=/usr/local/bin/gk-register

for a in "$@"; do
  case "$a" in
    gatekeeper-shim*|mcp-gatekeeper*) exec "$ORIG" "$@" ;;
  esac
done

# перехватываем только добавление/замену (-r, - -, файл)
if [[ "$#" -ge 1 && ( "$1" == "-r" || "$1" == "-" || -f "$1" ) ]]; then
  # регистрируем как таймер-намерение (project=shim)
  timeout 5 "$HELPER" port 0 "crontab job" "shim" "shim" >/dev/null 2>&1 || true
fi

exec "$ORIG" "$@"
